# ── Backend ───────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (replace with your M0 cluster URI)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/bcc_cvote?retryWrites=true&w=majority

# Flask secret keys (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=replace-with-random-32-byte-hex
SECRET_KEY=replace-with-another-random-32-byte-hex

# Flask environment: development | production
FLASK_ENV=development

# CORS allowed origin (frontend URL)
# Dev: http://localhost:5173   Prod: http://<k3s-public-ip>:30080
FRONTEND_URL=http://localhost:5173

# Gunicorn workers (prod only, ignored in dev Flask server)
GUNICORN_WORKERS=2

# ── Frontend ──────────────────────────────────────────────────────────────────
# Dev: Vite proxies /api to backend automatically (see vite.config.js)
# Prod: leave empty — nginx proxies /api to backend service
VITE_API_URL=
